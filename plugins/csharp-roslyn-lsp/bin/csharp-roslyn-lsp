#!/usr/bin/env bash
# csharp-roslyn-lsp — launcher for Microsoft.CodeAnalysis.LanguageServer
#
# Locates the Roslyn language server bundled with the VS Code C# extension
# (publisher: ms-dotnettools, ID: csharp), runs it via the bundled .NET runtime
# (or system dotnet >= 10 if no bundled runtime is present), and forwards all
# arguments. Picks the highest installed version of each.
#
# This wrapper exists because Claude Code's stock csharp-ls plugin cannot load
# .csproj files generated by some toolchains (notably Unity's project export);
# Roslyn LSP — the same backend VS Code's C# extension uses — handles them.
#
# Dependency: VS Code C# extension installed at the user level.

set -euo pipefail

# --- OS / arch tags used in VS Code extension folder names ---------------------
case "$(uname -s)" in
  Darwin) os_tag="darwin" ;;
  Linux)  os_tag="linux"  ;;
  *) echo "csharp-roslyn-lsp: unsupported OS '$(uname -s)' (need Darwin or Linux)" >&2; exit 1 ;;
esac
case "$(uname -m)" in
  arm64|aarch64) arch_tag="arm64" ;;
  x86_64|amd64)  arch_tag="x64"   ;;
  *) echo "csharp-roslyn-lsp: unsupported CPU '$(uname -m)' (need arm64 or x86_64)" >&2; exit 1 ;;
esac

# --- Locate Microsoft.CodeAnalysis.LanguageServer.dll --------------------------
ext_glob="${HOME}/.vscode/extensions/ms-dotnettools.csharp-*-${os_tag}-${arch_tag}"
roslyn_dll=""
# Use natural version sort and pick the highest matching version that has the DLL.
while IFS= read -r dir; do
  candidate="${dir}/.roslyn/Microsoft.CodeAnalysis.LanguageServer.dll"
  [[ -f "${candidate}" ]] && roslyn_dll="${candidate}"
done < <(ls -d ${ext_glob} 2>/dev/null | sort -V)

if [[ -z "${roslyn_dll}" ]]; then
  echo "csharp-roslyn-lsp: VS Code C# extension not found." >&2
  echo "  Searched: ${ext_glob}/.roslyn/Microsoft.CodeAnalysis.LanguageServer.dll" >&2
  echo "  Install the 'C#' extension by ms-dotnettools in VS Code, or download" >&2
  echo "  the .vsix from https://marketplace.visualstudio.com/items?itemName=ms-dotnettools.csharp" >&2
  exit 1
fi

# --- Locate a .NET host that can run the DLL -----------------------------------
# Recent Roslyn LSP builds require .NET 10+. The VS Code C# extension installs a
# matching runtime via the ms-dotnettools.vscode-dotnet-runtime extension; prefer
# that to avoid surprising the user with a system dotnet version mismatch.
if [[ "${os_tag}" == "darwin" ]]; then
  rt_base="${HOME}/Library/Application Support/Code/User/globalStorage/ms-dotnettools.vscode-dotnet-runtime/.dotnet"
else
  rt_base="${HOME}/.config/Code/User/globalStorage/ms-dotnettools.vscode-dotnet-runtime/.dotnet"
fi

dotnet_host=""
if [[ -d "${rt_base}" ]]; then
  while IFS= read -r dir; do
    [[ -x "${dir}/dotnet" ]] && dotnet_host="${dir}/dotnet"
  done < <(ls -d "${rt_base}/"*"~${arch_tag}~aspnetcore" 2>/dev/null | sort -V)
fi

if [[ -z "${dotnet_host}" ]] && command -v dotnet >/dev/null 2>&1; then
  # Fall back to system dotnet if it can host the language server.
  dotnet_host="$(command -v dotnet)"
fi

if [[ -z "${dotnet_host}" ]]; then
  echo "csharp-roslyn-lsp: no .NET host found." >&2
  echo "  Install the VS Code C# extension (it brings a matching runtime via" >&2
  echo "  ms-dotnettools.vscode-dotnet-runtime) or .NET 10+ from" >&2
  echo "  https://dotnet.microsoft.com/download" >&2
  exit 1
fi

# --- Launch --------------------------------------------------------------------
log_dir="${TMPDIR:-/tmp}/claude-csharp-roslyn-lsp"
mkdir -p "${log_dir}"

exec "${dotnet_host}" "${roslyn_dll}" \
  --stdio \
  --logLevel Information \
  --extensionLogDirectory "${log_dir}" \
  "$@"
